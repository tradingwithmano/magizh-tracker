{
  "name": "magizh-trader-tracker",
  "version": "1.0.0",
  "description": "Magizh Trader - Weekly & Monthly MNQ Futures Profit Tracker",
  "main": "server/index.js",
  "scripts": {
    "start":       "node server/index.js",
    "dev":         "nodemon server/index.js",

    "build":       "node scripts/run.js build",
    "clean":       "node scripts/run.js clean",
    "clean:db":    "node scripts/run.js clean:db",
    "lint":        "node scripts/run.js lint",
    "backup":      "node scripts/run.js backup",
    "restore":     "node scripts/run.js restore",
    "info":        "node scripts/run.js info",

    "pm2:start":   "pm2 start server/index.js --name magizh-tracker",
    "pm2:stop":    "pm2 stop magizh-tracker",
    "pm2:restart": "pm2 restart magizh-tracker",
    "pm2:status":  "pm2 status magizh-tracker",
    "pm2:logs":    "pm2 logs magizh-tracker",
    "pm2:save":    "pm2 save && pm2 startup"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "sql.js": "1.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}